# ============================================================
# DATABASE (Railway provides this automatically when you add
# a PostgreSQL plugin — copy the value from the plugin vars)
# ============================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/wellness_hub"

# ============================================================
# NEXTAUTH
# Generate secret with: openssl rand -base64 32
# NEXTAUTH_URL & NEXT_PUBLIC_APP_URL = your Railway domain
# e.g. https://wellness-hub-production.up.railway.app
# ============================================================
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="https://your-app.up.railway.app"
NEXT_PUBLIC_APP_URL="https://your-app.up.railway.app"

# ============================================================
# AI — Anthropic Claude (required for meal plan generation)
# ============================================================
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key-here"

# ============================================================
# STRIPE (required for subscription/billing features)
# ============================================================
STRIPE_SECRET_KEY="sk_live_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_your-premium-monthly-id"
STRIPE_PREMIUM_ANNUAL_PRICE_ID="price_your-premium-annual-id"
STRIPE_FAMILY_MONTHLY_PRICE_ID="price_your-family-monthly-id"
STRIPE_FAMILY_ANNUAL_PRICE_ID="price_your-family-annual-id"

# ============================================================
# EMAIL — Resend (required for transactional emails)
# ============================================================
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@yourdomain.com"

# ============================================================
# INSTACART (optional — grocery ordering integration)
# ============================================================
# INSTACART_API_KEY="your-instacart-api-key"
# INSTACART_ENV="production"
# EMAIL_FROM="noreply@wellnesshub.com"